#include <stdio.h>
#include <stdlib.h>

/* run this program using the console pauser or add your own getch, system("pause") or input loop */

int main(void) {
	int contador;
	
	for (contador = 1; contador <= 10; contador ++) {
		printf("%d\n", contador);
	}
	return 0;
}



EXEMPLO 06

#include <stdio.h>
#include <stdlib.h>

/* run this program using the console pauser or add your own getch, system("pause") or input loop */

int main(void) {
	int contador = 1;
	
	for (;;) {
		if (contador > 10){
			break;
		}
		printf("%d\n", contador);
		contador++;
	}
	return 0;
}
