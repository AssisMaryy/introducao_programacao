
EXEMPLO 01
include <stdio.h>
#include <stdlib.h>


int main(void) {
	int opcao;
	printf("Digite uma opcao de 1 a 3: ");
	scanf("%d", &opcao);
	
	switch(opcao) {
		case 1:
			printf("Voce escolheu a opcao 1.\n");
			break;
		case 2:
			printf("Voce escolheu a opcao 2.\n");
			break;
		case 3:
			printf("Voce escolheu a opcao 3.\n");
			break;
		default:
			printf("Opcao invalida\n");
	}
	return 0;
}

EXEMPLO 02
#include <stdio.h>
#include <stdlib.h>

int main(void) {
    int opcao;

    printf("===== MENU ======\n");
    printf("1 - Cadastrar aluno\n");
    printf("2 - Consultar aluno\n");
    printf("3 - Excluir aluno\n");
    printf("4 - Sair\n");
    printf("Escolha uma opcao: \n");
    scanf("%d", &opcao);

    switch(opcao) {
        case 1:
            printf("Opcao escolhida: Cadastrar aluno.\n");
            break;
        case 2:
            printf("Opcao escolhida: Consultar aluno.\n");
            break;
        case 3:
            printf("Opcao escolhida: Excluir aluno.\n");
            break;
        case 4:
            printf("Encerrando o programa.\n");
            break;
        default:
            printf("Opcao invalida.\n");
    }

    return 0;
}



EXEMPLO 03
#include <stdio.h>
#include <stdlib.h>

int main(void) {
    char conceito;
    printf("Digite o conceito do aluno: ");
    scanf("%c", &conceito);

    switch(conceito) {
        case 'A':
            printf("Excelente.\n");
            break;
        case 'B':
            printf("Bom.\n");
            break;
        case 'C':
            printf("Regular.\n");
            break;
        case 'D':
            printf("Insuficiente.\n");
            break;
        default:
            printf("Conceito invalido.\n");
    }

    return 0;
}



